rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAdmin() {
      return request.auth != null && request.auth.token.email == "edimar.varoni@gmail.com";
    }

    match /listings/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    match /posts/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /catalogs/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default deny for sensitive paths, allow read for public content
    match /{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
