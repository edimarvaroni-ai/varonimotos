{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile in the marketplace",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Listing": {
      "title": "Listing",
      "description": "A motorcycle listed for sale",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "brand": { "type": "string" },
        "model": { "type": "string" },
        "year": { "type": "number" },
        "price": { "type": "number" },
        "condition": { "type": "string", "enum": ["Nova", "Seminova", "Usada"] },
        "kilometers": { "type": "number" },
        "description": { "type": "string" },
        "images": { "type": "array", "items": { "type": "string" } },
        "category": { "type": "string" },
        "specs": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "sold", "deleted"] },
        "isPremium": { "type": "boolean" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "city": { "type": "string" },
            "state": { "type": "string" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "brand", "model", "price", "images", "location"]
    },
    "Chat": {
      "title": "Chat",
      "description": "Conversation between buyer and seller",
      "type": "object",
      "properties": {
        "listingId": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["listingId", "participants"]
    },
    "Message": {
      "title": "Message",
      "description": "Individual message in a chat",
      "type": "object",
      "properties": {
        "chatId": { "type": "string" },
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["chatId", "senderId", "content"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Marketplace user profiles"
    },
    "/listings/{listingId}": {
      "schema": "Listing",
      "description": "Motorcycle marketplace listings"
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Conversation threads"
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Messages within a chat"
    },
    "/users/{userId}/favorites/{listingId}": {
      "schema": "object",
      "description": "User favorite listings"
    }
  }
}
